    },
    "tokenColors": [
        {
            "scope": [
                // 默认
                "source",
                "meta.embedded",
                // 符号
                "punctuation.parenthesis",
                "punctuation.curlybrace",
                "punctuation.squarebracket",
                "punctuation.terminator",
                "punctuation.separator",
                "punctuation.section",
                // "punctuation.definition.entity",
                // 变量
                "variable.other.readwrite",
                "entity.name.variable",
                "support.type.property-name",
                "entity.other.attribute-name",
                // 笔记
                "text.html.markdown",
            ],
            "settings": {
                "foreground": "#abb2bf",
            }
        },
        {
            "scope": [
                // 错误
                "invalid",
                "message.error",
            ],
            "settings": {
                "foreground": "#f8f8f0",
            }
        },
        {
            "scope": [
                // 注释
                "comment",
                // 排除
                "support.other.excluded",
                // 笔记
                "punctuation.definition.heading",
                "punctuation.definition.bold",
                "punctuation.definition.italic",
            ],
            "settings": {
                "foreground": "#676f7d",
            }
        },
        {
            "scope": [
                // 关键字
                "keyword",
                "keyword.operator.logical",
                "keyword.operator.constructor",
                "entity.name.function.macro",
                "entity.name.function.member.overload",
                "entity.name.function.preprocessor",
                "constant.language",
                "support.type",
                "variable.language",
                "punctuation.definition.entity.css",
                // 运算符
                "keyword.operator",
                "punctuation.accessor",
                "storage.type.function",
                // 注释文档名称
                "comment.documentation.name",
                // 仓库
                "storage",
                // JSON
                "support.type.property-name.json",
                // 关键字(Tag)
                "meta.tag",
                "entity.other.keyframe-offset",
                // 笔记
                "markup.deleted",
            ],
            "settings": {
                "foreground": "#e06c75",
            }
        },
        {
            "scope": [
                // 数字
                "constant.numeric",
                // 单位
                "keyword.other.unit",
            ],
            "settings": {
                "foreground": "#c678dd",
            }
        },
        {
            "scope": [
                // 命名空间
                "entity.name.namespace",
                // 类
                "support.class",
                "entity.name.type",
                "entity.other.attribute",
                "entity.name.scope-resolution",
                "entity.name.class",
                "variable.other.object",
                "variable.other.constant.object",
                "storage.type.numeric.go",
                "storage.type.byte.go",
                "storage.type.boolean.go",
                "storage.type.string.go",
                "storage.type.uintptr.go",
                "storage.type.error.go",
                "storage.type.rune.go",
                "storage.type.cs",
                "storage.type.generic.cs",
                "storage.type.modifier.cs",
                "storage.type.variable.cs",
                "storage.type.annotation.java",
                "storage.type.generic.java",
                "storage.type.java",
                "storage.type.object.array.java",
                "storage.type.primitive.array.java",
                "storage.type.primitive.java",
                "storage.type.token.java",
                "storage.type.groovy",
                "storage.type.annotation.groovy",
                "storage.type.parameters.groovy",
                "storage.type.generic.groovy",
                "storage.type.object.array.groovy",
                "storage.type.primitive.array.groovy",
                "storage.type.primitive.groovy",
                // 结构体
                "entity.name.type.struct",
                // 接口
                "entity.name.type.interface",
                // 类(TS)
                "meta.type.cast.expr",
                "meta.type.new.expr",
                "support.constant.math",
                "support.constant.dom",
                "support.constant.json",
                "entity.other.inherited-class",
                // 属性命名空间(Tag)
                "entity.other.attribute-name.namespace",
                // 属性(Tag)
                "entity.other.attribute-name",
                // 选择器(CSS)
                "entity.name.tag.css",
                "entity.name.tag.less",
                "entity.other.attribute-name.class.css",
                "source.css entity.other.attribute-name.class",
                "entity.other.attribute-name.id.css",
                "entity.other.attribute-name.parent-selector.css",
                "entity.other.attribute-name.parent.less",
                "source.css entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element.css",
                "source.css.less entity.other.attribute-name.id",
                "entity.other.attribute-name.scss",
                // 笔记
                "markup.heading",
                "markup.changed",
                "markup.underline.link",
            ],
            "settings": {
                "foreground": "#61afef",
            }
        },
        {
            "scope": [
                // 常量
                "variable.other.constant",
                "variable.other.constant.property",
                "entity.other.attribute-name.pseudo-class",
                "entity.name.variable.enum-member",
                // 枚举
                "entity.name.type.enum",
                "variable.other.enummember",
                // 正则/转义字符
                "string.regexp",
                "constant.other",
                // 笔记
                "string.other.link.title.markdown",
            ],
            "settings": {
                "foreground": "#8396eb",
            }
        },
        {
            "scope": [
                // 属性
                "variable.other.property",
                "variable.other.object.property",
                "support.constant.property",
                "support.constant",
                // 笔记
                "punctuation.definition.quote",
                "punctuation.definition.list",
                "markup.inline.raw",
                "markup.fenced_code.block",
                "punctuation.definition.table",
                "punctuation.separator.table",
            ],
            "settings": {
                "foreground": "#9fb8d6",
            }
        },
        {
            "scope": [
                // 方法
                "entity.name.function",
                "support.function",
                "support.constant.handlebars",
                "source.powershell variable.other.member",
                "entity.name.operator.custom-literal",
            ],
            "settings": {
                "foreground": "#98c379",
            }
        },
        {
            "scope": [
                // 形参
                "variable.parameter",
            ],
            "settings": {
                "foreground": "#d19a66",
            }
        },
        {
            "scope": [
                // 事件
                "variable.other.event",
                // 笔记
                "markup.inserted",
            ],
            "settings": {
                "foreground": "#c4c671",
            }
        },
        {
            "scope": [
                // 字符串
                "string",
                "string.value",
                "string.template",
                "constant.other.symbol",
                // 字符串(Tag)
                "string.tag",
            ],
            "settings": {
                "foreground": "#e5c07b",
            }
        },
        {
            "scope": [
                // 嵌入式字符串
                "string.embedded",
                "punctuation.definition.interpolation",
                "punctuation.definition.template-expression",
                "punctuation.section.embedded",
                "constant.character",
                "constant.character.entity.named",
            ],
            "settings": {
                "foreground": "#f9aa5f",
            }
        },
        {
            "scope": [
                // 运算符重载
                "entity.name.function.member.overload",
                // 命名空间(Tag)
                "entity.name.tag.namespace",
                // 属性命名空间(Tag)
                "entity.other.attribute-name.namespace",
                // 笔记
                "markup.heading",
                "markup.bold",
                "punctuation.definition.table",
            ],
            "settings": {
                "fontStyle": "bold",
            }
        },
        {
            "scope": [
                // 笔记
                "markup.italic",
            ],
            "settings": {
                "fontStyle": "italic",
            }
        },
        {
            "scope": [
                // 笔记
                "markup.italic markup.bold",
                "markup.bold markup.italic",
            ],
            "settings": {
                "fontStyle": "italic bold",
            }
        },
        {
            "scope": [
                // 结构体
                "entity.name.type.struct",
                // 笔记
                "markup.underline",
            ],
            "settings": {
                "fontStyle": "underline",
            }
        },
        {
            "scope": [
                // 笔记
                "markup.strikethrough",
            ],
            "settings": {
                "fontStyle": "strikethrough",
            }
        },
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "*.static": {
            "fontStyle": "bold",
        },
        "variable": {
            "fontStyle": "italic",
        },
        "parameter": {
            "fontStyle": "italic",
        },
        "*.local": {
            "foreground": "#abb2bf",
        }
        // "*.readonly": {
        //     "foreground": "#8396eb",
        // },
    }
}